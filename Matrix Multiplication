#include <stdio.h>
int main() {
    int A[3][4] = {
        {1,2,3,4},
        {5,6,7,8},
        {9,1,2,3}
    };
    int B[4][2] = {
        {1,2},
        {3,4},
        {5,6},
        {7,8}
};
int C[3][2] ={0};
for(int i = 0; i < 3; i++) {
    for (int j = 0; j < 2; j++) {
        for (int k = 0; k < 4; k++) {
            C[i][j] += A[i][k] * B[k][j];
        }
    }
}
printf("Result matrix C:\n");
for (int i = 0; i<3; i++) {
    for(int j =0; j < 2; j++){
        printf("%d ", C[i][j]);
    }
    printf("\n");
  } 
  return 0;
} 
